---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const shows = (await getCollection('shows')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Shows — Victor Ashveil"
  description="Explore the formats Victor Ashveil performs: corporate events, private parties, stage shows, and virtual performances."
>
  <Header />

  <!-- Page hero -->
  <section class="pt-40 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold text-xs tracking-[0.3em] uppercase mb-4">What's Available</p>
      <h1 class="font-display text-5xl md:text-7xl font-light leading-tight">
        Formats &<br /><em class="italic text-gold">Engagements</em>
      </h1>
      <p class="text-text-secondary mt-6 text-lg leading-relaxed max-w-2xl">
        Every context is different. Each format below has been developed specifically for its
        setting — not adapted from something else.
      </p>
    </div>
  </section>

  <!-- Shows list -->
  <section class="pb-24 px-6">
    <div class="max-w-5xl mx-auto space-y-2">
      {shows.map(async (show, i) => {
        const { Content } = await show.render();
        return (
          <div class="group border border-white/5 bg-surface/40 hover:bg-surface hover:border-gold/15 transition-all duration-300">
            <div class="p-8 md:p-12">
              <div class="flex flex-col md:flex-row md:items-start gap-8">
                <!-- Icon + number -->
                <div class="flex-shrink-0 flex flex-col items-start">
                  <span class="font-display text-4xl text-gold">{show.data.icon}</span>
                  <span class="text-text-muted text-xs mt-2 tabular-nums">0{i + 1}</span>
                </div>

                <!-- Content -->
                <div class="flex-1">
                  <h2 class="font-display text-3xl md:text-4xl font-light mb-2 group-hover:text-gold transition-colors">{show.data.title}</h2>
                  <p class="text-text-secondary text-sm mb-6">{show.data.subtitle}</p>

                  <!-- Highlights -->
                  {show.data.highlights.length > 0 && (
                    <ul class="grid sm:grid-cols-2 gap-2 mb-8">
                      {show.data.highlights.map(h => (
                        <li class="flex items-start gap-2 text-sm text-text-secondary">
                          <span class="text-gold mt-1 text-xs">◆</span>
                          {h}
                        </li>
                      ))}
                    </ul>
                  )}

                  <!-- Body content -->
                  <div class="prose prose-invert prose-sm max-w-none text-text-secondary leading-relaxed">
                    <Content />
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-surface/40 border-t border-white/5">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl font-light mb-4">Not sure which format suits your event?</h2>
      <p class="text-text-secondary mb-8 leading-relaxed">
        The first conversation is always about understanding your needs — not selling you a show.
        Get in touch and Victor will help you find the right approach.
      </p>
      <a href="/contact" class="inline-block px-8 py-3.5 bg-gold text-background font-medium text-sm tracking-wide hover:bg-gold-light transition-colors">
        Start a Conversation
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .prose p { margin-bottom: 1em; }
  .prose p:last-child { margin-bottom: 0; }
</style>
