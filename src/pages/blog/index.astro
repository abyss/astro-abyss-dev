---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="The Journal — Victor Ashveil"
  description="Thoughts on performance, psychology, and the art of wonder."
>
  <Header />

  <!-- Page hero -->
  <section class="pt-40 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold text-xs tracking-[0.3em] uppercase mb-4">Writing</p>
      <h1 class="font-display text-5xl md:text-7xl font-light leading-tight">
        The<br /><em class="italic text-gold">Journal</em>
      </h1>
      <p class="text-text-secondary mt-6 text-lg">
        Thoughts on performance, psychology, and the art of wonder.
      </p>
    </div>
  </section>

  <!-- Posts list -->
  <section class="pb-24 px-6">
    <div class="max-w-3xl mx-auto space-y-0">
      {posts.map(post => (
        <article class="group border-t border-white/5 py-10 hover:border-gold/20 transition-colors">
          <div class="flex flex-col sm:flex-row sm:items-start gap-4 sm:gap-8">
            <time class="text-text-muted text-sm flex-shrink-0 pt-1 sm:w-36 tabular-nums">
              {formatDate(post.data.date)}
            </time>
            <div class="flex-1">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.map(tag => (
                  <span class="text-xs text-text-muted border border-white/10 px-2 py-0.5 tracking-wide uppercase">{tag}</span>
                ))}
              </div>
              <h2 class="font-display text-2xl md:text-3xl font-light mb-3 group-hover:text-gold transition-colors">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p class="text-text-secondary text-sm leading-relaxed mb-4">{post.data.description}</p>
              <a href={`/blog/${post.slug}`} class="text-gold text-sm border-b border-gold/40 pb-0.5 hover:border-gold transition-colors">
                Read more →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <Footer />
</BaseLayout>
